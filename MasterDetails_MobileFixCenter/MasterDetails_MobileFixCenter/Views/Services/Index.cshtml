@model IEnumerable<MasterDetails_MobileFixCenter.Models.Service>
@using PagedList
@using PagedList.Mvc
@{
    ViewBag.Title = "Services";
}

<style>
    .page-hero {
        background: linear-gradient(135deg, #0f2057 0%, #1a3284 55%, #2348b0 100%);
        border-radius: 16px;
        padding: 32px 36px;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
        position: relative;
        overflow: hidden;
    }

        .page-hero::before {
            content: '';
            position: absolute;
            right: -60px;
            top: -60px;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            pointer-events: none;
        }

        .page-hero::after {
            content: '';
            position: absolute;
            right: 80px;
            bottom: -80px;
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            pointer-events: none;
        }

    .hero-left {
        position: relative;
        z-index: 1;
    }

    .hero-eyebrow {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.45);
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .hero-eyebrow::before {
            content: '';
            width: 20px;
            height: 2px;
            background: rgba(255,255,255,0.3);
            border-radius: 2px;
            display: inline-block;
        }

    .hero-title {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.02em;
        margin: 0 0 6px;
    }

        .hero-title span {
            color: #7eb5ff;
        }

    .hero-sub {
        font-size: 13px;
        color: rgba(255,255,255,0.5);
        margin: 0;
    }

    .hero-right {
        position: relative;
        z-index: 1;
    }

    .btn-create {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #ffffff;
        color: #0f2057 !important;
        font-family: 'Syne', sans-serif;
        font-size: 13px;
        font-weight: 800;
        padding: 11px 22px;
        border-radius: 10px;
        text-decoration: none !important;
        transition: transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 4px 16px rgba(0,0,0,0.18);
        white-space: nowrap;
    }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.26);
            color: #0f2057 !important;
            text-decoration: none !important;
        }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: #ffffff;
        border: 1.5px solid rgba(26,50,132,0.10);
        border-radius: 12px;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 18px;
    }

        .stat-icon.blue {
            background: #eff4ff;
            color: #1a3284;
        }

        .stat-icon.green {
            background: #f0fdf4;
            color: #16a34a;
        }

        .stat-icon.amber {
            background: #fffbeb;
            color: #d97706;
        }

    .stat-value {
        font-family: 'Syne', sans-serif;
        font-size: 22px;
        font-weight: 800;
        color: #0f2057;
        line-height: 1;
    }

    .stat-label {
        font-size: 12px;
        color: #5a6a8a;
        margin-top: 3px;
    }

    .table-card {
        background: #ffffff;
        border: 1.5px solid rgba(26,50,132,0.10);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 24px;
    }

    .table-card-header {
        padding: 18px 24px;
        border-bottom: 1.5px solid rgba(26,50,132,0.08);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        background: #f8faff;
    }

    .table-card-title {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: #0f2057;
        display: flex;
        align-items: center;
        gap: 9px;
        margin: 0;
    }

        .table-card-title i {
            color: #2348b0;
            font-size: 14px;
        }

    .table-count {
        background: #eff4ff;
        color: #1a3284;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid rgba(26,50,132,0.14);
    }

    .services-table {
        width: 100%;
        border-collapse: collapse;
    }

        .services-table thead th {
            padding: 13px 24px;
            font-family: 'Syne', sans-serif;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #5a6a8a;
            background: #f4f7fd;
            border-bottom: 1.5px solid rgba(26,50,132,0.08);
            white-space: nowrap;
        }

            .services-table thead th:last-child {
                text-align: right;
            }

        .services-table tbody tr {
            border-bottom: 1px solid rgba(26,50,132,0.06);
            transition: background 0.15s;
        }

            .services-table tbody tr:last-child {
                border-bottom: none;
            }

            .services-table tbody tr:hover {
                background: #f8faff;
            }

        .services-table tbody td {
            padding: 15px 24px;
            font-size: 14px;
            color: #0d1a3a;
            vertical-align: middle;
        }

            .services-table tbody td:last-child {
                text-align: right;
            }

    .service-name-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .service-badge {
        width: 34px;
        height: 34px;
        background: linear-gradient(135deg, #eff4ff, #dbeafe);
        border: 1px solid rgba(26,50,132,0.14);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
        color: #1a3284;
    }

    .service-name {
        font-weight: 600;
        color: #0f2057;
        font-size: 14px;
    }

    .action-group {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 6px;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 13px;
        border-radius: 7px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none !important;
        transition: background 0.15s, transform 0.12s;
        white-space: nowrap;
        font-family: 'DM Sans', sans-serif;
    }

        .btn-action:hover {
            transform: translateY(-1px);
            text-decoration: none !important;
        }

    .btn-edit {
        background: #eff4ff;
        color: #1a3284 !important;
        border: 1px solid rgba(26,50,132,0.15);
    }

        .btn-edit:hover {
            background: #dbeafe;
            color: #0f2057 !important;
        }

    .btn-details {
        background: #f4f7fd;
        color: #5a6a8a !important;
        border: 1px solid rgba(26,50,132,0.10);
    }

        .btn-details:hover {
            background: #e8edf8;
            color: #0f2057 !important;
        }

    .btn-delete {
        background: #fff1f1;
        color: #dc2626 !important;
        border: 1px solid rgba(220,38,38,0.18);
    }

        .btn-delete:hover {
            background: #fee2e2;
            color: #991b1b !important;
        }

    .empty-state {
        text-align: center;
        padding: 60px 24px;
    }

    .empty-icon {
        width: 64px;
        height: 64px;
        background: #eff4ff;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        color: #1a3284;
        margin: 0 auto 16px;
    }

    .empty-title {
        font-family: 'Syne', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: #0f2057;
        margin-bottom: 6px;
    }

    .empty-sub {
        font-size: 13px;
        color: #5a6a8a;
    }

    .pagination-wrap {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
        padding: 4px 0;
    }

    .pagination-info {
        font-size: 13px;
        color: #5a6a8a;
    }

    .pagination-wrap .pagination {
        margin: 0;
        display: flex;
        gap: 4px;
    }

        .pagination-wrap .pagination li a,
        .pagination-wrap .pagination li span {
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 34px;
            height: 34px;
            padding: 0 10px;
            background: #ffffff;
            border: 1.5px solid rgba(26,50,132,0.12);
            border-radius: 8px !important;
            font-size: 13px;
            font-weight: 600;
            color: #5a6a8a;
            text-decoration: none;
            transition: all 0.15s;
        }

            .pagination-wrap .pagination li a:hover {
                background: #eff4ff;
                border-color: rgba(26,50,132,0.25);
                color: #1a3284;
            }

        .pagination-wrap .pagination li.active span,
        .pagination-wrap .pagination li.active a {
            background: linear-gradient(135deg, #1a3284, #2348b0);
            border-color: #1a3284;
            color: #ffffff !important;
        }

        .pagination-wrap .pagination li.disabled span {
            opacity: 0.4;
            cursor: not-allowed;
        }

    @@media (max-width: 640px) {
        .stats-row {
            grid-template-columns: 1fr;
        }

        .page-hero {
            padding: 24px 20px;
        }

        .hero-title {
            font-size: 22px;
        }

        .services-table thead th,
        .services-table tbody td {
            padding: 12px 16px;
        }
    }
</style>

@* ── Page Hero ── *@
<div class="page-hero">
    <div class="hero-left">
        <div class="hero-eyebrow">PhixPro Management</div>
        <h1 class="hero-title">Repair <span>Services</span></h1>
        <p class="hero-sub">Manage all service types offered at your repair center</p>
    </div>
    <div class="hero-right">
        @Html.ActionLink("+ Add New Service", "Create", null, new { @class = "btn-create" })
    </div>
</div>

@* ── Stats ── *@
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fas fa-tools"></i></div>
        <div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label">Total Services</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
        <div>
            <div class="stat-value">Active</div>
            <div class="stat-label">All services live</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fas fa-bolt"></i></div>
        <div>
            <div class="stat-value">Same Day</div>
            <div class="stat-label">Avg. turnaround</div>
        </div>
    </div>
</div>

@* ── Table Card ── *@
<div class="table-card">
    <div class="table-card-header">
        <h2 class="table-card-title">
            <i class="fas fa-list-ul"></i>
            All Services
            <span class="table-count">@Model.Count() records</span>
        </h2>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-tools"></i></div>
            <div class="empty-title">No services yet</div>
            <p class="empty-sub">Click "+ Add New Service" to create your first repair service.</p>
        </div>
    }
    else
    {
        <table class="services-table">
            <thead>
                <tr>
                    <th style="width:48px">#</th>
                    <th>@Html.DisplayNameFor(model => model.ServiceName)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="color:#9ca3af; font-size:13px;">@i</td>
                        <td>
                            <div class="service-name-cell">
                                <div class="service-badge"><i class="fas fa-wrench"></i></div>
                                <span class="service-name">@Html.DisplayFor(m => item.ServiceName)</span>
                            </div>
                        </td>
                        <td>
                            <div class="action-group">
                                <div class="action-group">
                                    <a href="@Url.Action("Edit", new { id = item.ServiceId })" class="btn-action btn-edit">
                                        <i class="fas fa-pen"></i> Edit
                                    </a>
                                    <a href="@Url.Action("Details", new { id = item.ServiceId })" class="btn-action btn-details">
                                        <i class="fas fa-eye"></i> Details
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.ServiceId })" class="btn-action btn-delete">
                                        <i class="fas fa-trash-alt"></i> Delete
                                    </a>
                                </div>
                            </div>
                        </td>
                    </tr>
                    i++;
                }
            </tbody>
        </table>
    }
</div>

@* ── Pagination ── *@
<div class="pagination-wrap">
    <span class="pagination-info">Showing @Model.Count() service(s)</span>
    <div>
        @Html.PagedListPager(Model as IPagedList, Page => Url.Action("Index", new { page = Page }))
    </div>
</div>
