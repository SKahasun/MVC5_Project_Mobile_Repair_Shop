@model MasterDetails_MobileFixCenter.Models.Service
@{
    ViewBag.Title = "Service Details";
}

<style>
    .form-page-hero {
        background: linear-gradient(135deg, #0f2057 0%, #1a3284 55%, #2348b0 100%);
        border-radius: 16px;
        padding: 28px 36px;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        position: relative;
        overflow: hidden;
    }

        .form-page-hero::before {
            content: '';
            position: absolute;
            right: -50px;
            top: -50px;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            pointer-events: none;
        }

    .fph-left {
        position: relative;
        z-index: 1;
    }

    .fph-eyebrow {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.45);
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .fph-eyebrow::before {
            content: '';
            width: 18px;
            height: 2px;
            background: rgba(255,255,255,0.3);
            border-radius: 2px;
            display: inline-block;
        }

    .fph-title {
        font-family: 'Syne', sans-serif;
        font-size: 24px;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.02em;
        margin: 0;
    }

        .fph-title span {
            color: #7eb5ff;
        }

    .fph-right {
        position: relative;
        z-index: 1;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.22);
        color: #ffffff !important;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 600;
        padding: 9px 18px;
        border-radius: 9px;
        text-decoration: none !important;
        transition: background 0.2s;
        white-space: nowrap;
    }

        .btn-back:hover {
            background: rgba(255,255,255,0.2);
            color: #fff !important;
            text-decoration: none !important;
        }

    .detail-card {
        background: #ffffff;
        border: 1.5px solid rgba(26,50,132,0.10);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 20px;
    }

    .detail-card-header {
        padding: 18px 28px;
        border-bottom: 1.5px solid rgba(26,50,132,0.08);
        background: #f8faff;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .detail-card-header-icon {
        width: 36px;
        height: 36px;
        background: #eff4ff;
        border: 1px solid rgba(26,50,132,0.14);
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a3284;
        font-size: 15px;
        flex-shrink: 0;
    }

    .detail-card-header-title {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: #0f2057;
        margin: 0;
    }

    .detail-card-header-badge {
        margin-left: auto;
        background: #f0fdf4;
        color: #16a34a;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid rgba(22,163,74,0.2);
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .detail-card-header-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #16a34a;
        }

    .detail-body {
        padding: 28px;
    }

    .detail-row {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid rgba(26,50,132,0.06);
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-row-icon {
        width: 36px;
        height: 36px;
        background: #eff4ff;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a3284;
        font-size: 13px;
        flex-shrink: 0;
    }

    .detail-row-content {
    }

    .detail-row-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #5a6a8a;
        margin-bottom: 4px;
    }

    .detail-row-value {
        font-family: 'Syne', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: #0f2057;
    }

    .detail-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        padding: 20px 28px;
        border-top: 1.5px solid rgba(26,50,132,0.08);
        background: #f8faff;
    }

    .btn-edit-lg {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #1a3284, #2348b0);
        color: #ffffff !important;
        font-family: 'Syne', sans-serif;
        font-size: 13px;
        font-weight: 800;
        padding: 11px 24px;
        border-radius: 10px;
        text-decoration: none !important;
        transition: filter 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 3px 12px rgba(26,50,132,0.28);
    }

        .btn-edit-lg:hover {
            filter: brightness(1.1);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(26,50,132,0.38);
            color: #fff !important;
            text-decoration: none !important;
        }

    .btn-cancel-sm {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #f4f7fd;
        border: 1.5px solid rgba(26,50,132,0.12);
        color: #5a6a8a !important;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 600;
        padding: 11px 20px;
        border-radius: 10px;
        text-decoration: none !important;
        transition: background 0.15s, color 0.15s;
    }

        .btn-cancel-sm:hover {
            background: #e8edf8;
            color: #0f2057 !important;
            text-decoration: none !important;
        }
</style>

@* ── Hero ── *@
<div class="form-page-hero">
    <div class="fph-left">
        <div class="fph-eyebrow">Services</div>
        <h1 class="fph-title">Service <span>Details</span></h1>
    </div>
    <div class="fph-right">
        @Html.ActionLink("← Back to List", "Index", null, new { @class = "btn-back" })
    </div>
</div>

@* ── Detail Card ── *@
<div class="detail-card">
    <div class="detail-card-header">
        <div class="detail-card-header-icon"><i class="fas fa-wrench"></i></div>
        <h2 class="detail-card-header-title">Service Record</h2>
        <span class="detail-card-header-badge">Active</span>
    </div>

    <div class="detail-body">
        <div class="detail-row">
            <div class="detail-row-icon"><i class="fas fa-hashtag"></i></div>
            <div class="detail-row-content">
                <div class="detail-row-label">Service ID</div>
                <div class="detail-row-value">#@Model.ServiceId</div>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-row-icon"><i class="fas fa-tag"></i></div>
            <div class="detail-row-content">
                <div class="detail-row-label">@Html.DisplayNameFor(m => m.ServiceName)</div>
                <div class="detail-row-value">@Html.DisplayFor(m => m.ServiceName)</div>
            </div>
        </div>
    </div>

    <div class="detail-actions">
        @Html.ActionLink("Edit this Service", "Edit", new { id = Model.ServiceId }, new { @class = "btn-edit-lg" })
        @Html.ActionLink("Back to List", "Index", null, new { @class = "btn-cancel-sm" })
    </div>
</div>
