@{
    ViewBag.Title = "Contact";
}

<style>
    /* ── Hero ── */
    .page-hero {
        background: linear-gradient(135deg, #0f2057 0%, #1a3284 55%, #2348b0 100%);
        border-radius: 16px;
        padding: 40px 48px;
        margin-bottom: 32px;
        position: relative;
        overflow: hidden;
        text-align: center;
    }

        .page-hero::before {
            content: '';
            position: absolute;
            right: -80px;
            top: -80px;
            width: 280px;
            height: 280px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            pointer-events: none;
        }

        .page-hero::after {
            content: '';
            position: absolute;
            left: -60px;
            bottom: -60px;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            pointer-events: none;
        }

    .ph-eyebrow {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.45);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        position: relative;
        z-index: 1;
    }

        .ph-eyebrow::before, .ph-eyebrow::after {
            content: '';
            width: 28px;
            height: 2px;
            background: rgba(255,255,255,0.25);
            border-radius: 2px;
            display: inline-block;
        }

    .ph-title {
        font-family: 'Syne', sans-serif;
        font-size: 36px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.03em;
        margin: 0 0 10px;
        position: relative;
        z-index: 1;
    }

        .ph-title span { color: #7eb5ff; }

    .ph-sub {
        font-size: 14px;
        color: rgba(255,255,255,0.55);
        max-width: 440px;
        margin: 0 auto;
        line-height: 1.65;
        position: relative;
        z-index: 1;
    }

    /* ── Main grid ── */
    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 24px;
        margin-bottom: 24px;
        align-items: start;
    }

    /* ── Info card ── */
    .info-card {
        background: #fff;
        border: 1.5px solid rgba(26,50,132,0.10);
        border-radius: 16px;
        overflow: hidden;
    }

    .card-header {
        padding: 16px 24px;
        border-bottom: 1.5px solid rgba(26,50,132,0.08);
        background: #f8faff;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .ch-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

        .ch-icon.blue  { background: #eff4ff; color: #1a3284; border: 1px solid rgba(26,50,132,0.14); }
        .ch-icon.green { background: #f0fdf4; color: #16a34a; border: 1px solid rgba(22,163,74,0.18); }
        .ch-icon.amber { background: #fffbeb; color: #d97706; border: 1px solid rgba(217,119,6,0.18); }

    .ch-title {
        font-family: 'Syne', sans-serif;
        font-size: 14px;
        font-weight: 700;
        color: #0f2057;
        margin: 0;
    }

    .card-body { padding: 20px 24px; }

    /* ── Contact rows ── */
    .contact-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid rgba(26,50,132,0.06);
    }

        .contact-row:last-child { border-bottom: none; }

    .cr-icon {
        width: 36px;
        height: 36px;
        background: #eff4ff;
        border: 1px solid rgba(26,50,132,0.12);
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a3284;
        font-size: 13px;
        flex-shrink: 0;
    }

    .cr-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #9ca3af;
        margin-bottom: 3px;
        font-family: 'DM Sans', sans-serif;
    }

    .cr-value {
        font-family: 'Syne', sans-serif;
        font-size: 14px;
        font-weight: 700;
        color: #0f2057;
    }

    .cr-value a {
        color: #1a3284 !important;
        text-decoration: none !important;
        transition: color 0.15s;
    }

        .cr-value a:hover { color: #2348b0 !important; }

    .cr-sub {
        font-size: 12px;
        color: #5a6a8a;
        margin-top: 2px;
        font-family: 'DM Sans', sans-serif;
    }

    /* Open badge */
    .open-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #f0fdf4;
        border: 1px solid rgba(22,163,74,0.2);
        color: #16a34a;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 12px;
        border-radius: 20px;
        font-family: 'Courier New', monospace;
        margin-top: 5px;
        display: inline-flex;
    }

        .open-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #16a34a;
            animation: pulse-dot 1.5s infinite;
        }

    @@keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.5; transform: scale(0.7); }
    }

    /* ── Form card ── */
    .form-card {
        background: #fff;
        border: 1.5px solid rgba(26,50,132,0.10);
        border-radius: 16px;
        overflow: hidden;
    }

    .field-row { margin-bottom: 16px; }

    .field-label {
        display: block;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-weight: 700;
        color: #0f2057;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 7px;
    }

    .field-input,
    .field-textarea {
        width: 100%;
        background: #f8faff;
        border: 1.5px solid rgba(26,50,132,0.14);
        border-radius: 9px;
        color: #0d1a3a;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        padding: 10px 14px;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
        box-sizing: border-box;
    }

        .field-input:focus,
        .field-textarea:focus {
            border-color: #1a3284;
            box-shadow: 0 0 0 3px rgba(26,50,132,0.10);
            background: #fff;
        }

    .field-textarea {
        resize: vertical;
        min-height: 110px;
        line-height: 1.6;
    }

    .field-row-2col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-bottom: 16px;
    }

    .form-footer {
        padding: 16px 24px;
        border-top: 1.5px solid rgba(26,50,132,0.08);
        background: #f8faff;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
    }

    .btn-send {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #1a3284, #2348b0);
        color: #fff !important;
        font-family: 'Syne', sans-serif;
        font-size: 13px;
        font-weight: 800;
        padding: 11px 26px;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        transition: filter 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 3px 12px rgba(26,50,132,0.28);
    }

        .btn-send:hover {
            filter: brightness(1.1);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(26,50,132,0.38);
        }

    /* ── Bottom info row ── */
    .bottom-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .bottom-card {
        background: #fff;
        border: 1.5px solid rgba(26,50,132,0.10);
        border-radius: 14px;
        padding: 20px;
        display: flex;
        align-items: flex-start;
        gap: 14px;
        transition: box-shadow 0.2s, border-color 0.2s;
    }

        .bottom-card:hover {
            box-shadow: 0 6px 24px rgba(15,32,87,0.10);
            border-color: rgba(26,50,132,0.22);
        }

    .bc-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

        .bc-icon.blue  { background: #eff4ff; color: #1a3284; border: 1px solid rgba(26,50,132,0.14); }
        .bc-icon.green { background: #f0fdf4; color: #16a34a; border: 1px solid rgba(22,163,74,0.18); }
        .bc-icon.amber { background: #fffbeb; color: #d97706; border: 1px solid rgba(217,119,6,0.18); }

    .bc-title {
        font-family: 'Syne', sans-serif;
        font-size: 13px;
        font-weight: 700;
        color: #0f2057;
        margin-bottom: 4px;
    }

    .bc-desc {
        font-size: 12px;
        color: #5a6a8a;
        line-height: 1.6;
    }

    @@media (max-width: 860px) {
        .contact-grid, .bottom-row { grid-template-columns: 1fr; }
        .field-row-2col { grid-template-columns: 1fr; }
        .ph-title { font-size: 26px; }
    }
</style>

@* ── Hero ── *@
<div class="page-hero">
    <div class="ph-eyebrow">Get In Touch</div>
    <h1 class="ph-title">Contact <span>PhixPro</span></h1>
    <p class="ph-sub">Have a question or want to book a repair? Reach out — we're open 6 days a week and happy to help.</p>
</div>

@* ── Main grid ── *@
<div class="contact-grid">

    @* ── Left: Contact info ── *@
    <div>
        <div class="info-card" style="margin-bottom:16px;">
            <div class="card-header">
                <div class="ch-icon blue"><i class="fas fa-map-marker-alt"></i></div>
                <h2 class="ch-title">Find Us</h2>
            </div>
            <div class="card-body">
                <div class="contact-row">
                    <div class="cr-icon"><i class="fas fa-store"></i></div>
                    <div>
                        <div class="cr-label">Address</div>
                        <div class="cr-value">47 Tech Avenue, Kafrul</div>
                        <div class="cr-sub">Dhaka 1216, Bangladesh</div>
                    </div>
                </div>
                <div class="contact-row">
                    <div class="cr-icon"><i class="fas fa-phone"></i></div>
                    <div>
                        <div class="cr-label">Phone</div>
                        <div class="cr-value"><a href="tel:+8801700744776">+880 1700-PHIXPRO</a></div>
                        <div class="cr-sub">Call or WhatsApp anytime</div>
                    </div>
                </div>
                <div class="contact-row">
                    <div class="cr-icon"><i class="fas fa-envelope"></i></div>
                    <div>
                        <div class="cr-label">Email</div>
                        <div class="cr-value"><a href="mailto:hello@phixpro.bd">hello@phixpro.bd</a></div>
                        <div class="cr-sub">We reply within a few hours</div>
                    </div>
                </div>
                <div class="contact-row">
                    <div class="cr-icon"><i class="fas fa-clock"></i></div>
                    <div>
                        <div class="cr-label">Opening Hours</div>
                        <div class="cr-value">Mon – Sat · 9:00 AM – 8:00 PM</div>
                        <div class="cr-sub">Closed Sundays &amp; public holidays</div>
                        <div class="open-badge">Open Now</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="info-card">
            <div class="card-header">
                <div class="ch-icon green"><i class="fab fa-whatsapp"></i></div>
                <h2 class="ch-title">Support Channels</h2>
            </div>
            <div class="card-body">
                <div class="contact-row">
                    <div class="cr-icon" style="background:#f0fdf4;color:#16a34a;border-color:rgba(22,163,74,0.18);"><i class="fab fa-whatsapp"></i></div>
                    <div>
                        <div class="cr-label">WhatsApp</div>
                        <div class="cr-value"><a href="https://wa.me/8801700744776">Chat with us</a></div>
                        <div class="cr-sub">Fastest response — usually within minutes</div>
                    </div>
                </div>
                <div class="contact-row">
                    <div class="cr-icon" style="background:#eff4ff;color:#1877f2;border-color:rgba(24,119,242,0.18);"><i class="fab fa-facebook-f"></i></div>
                    <div>
                        <div class="cr-label">Facebook</div>
                        <div class="cr-value"><a href="#">PhixPro Service Center</a></div>
                        <div class="cr-sub">Follow for tips, offers &amp; updates</div>
                    </div>
                </div>
                <div class="contact-row">
                    <div class="cr-icon" style="background:#fff3f3;color:#e1306c;border-color:rgba(225,48,108,0.18);"><i class="fab fa-instagram"></i></div>
                    <div>
                        <div class="cr-label">Instagram</div>
                        <div class="cr-value"><a href="#">@@phixpro.bd</a></div>
                        <div class="cr-sub">Behind-the-scenes &amp; repair showcases</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Right: Contact form ── *@
    <div class="form-card">
        <div class="card-header">
            <div class="ch-icon amber"><i class="fas fa-paper-plane"></i></div>
            <h2 class="ch-title">Send Us a Message</h2>
        </div>
        <div class="card-body">
            <div class="field-row-2col">
                <div>
                    <label class="field-label">Your Name</label>
                    <input type="text" class="field-input" placeholder="Full name" />
                </div>
                <div>
                    <label class="field-label">Phone Number</label>
                    <input type="tel" class="field-input" placeholder="+880 1700-000000" />
                </div>
            </div>
            <div class="field-row">
                <label class="field-label">Email Address</label>
                <input type="email" class="field-input" placeholder="you@example.com" />
            </div>
            <div class="field-row">
                <label class="field-label">Device Model</label>
                <input type="text" class="field-input" placeholder="e.g. Samsung Galaxy S24, iPhone 15" />
            </div>
            <div class="field-row">
                <label class="field-label">Describe the Issue</label>
                <textarea class="field-textarea" placeholder="Tell us what's wrong with your device — screen, battery, water damage, software, etc."></textarea>
            </div>
        </div>
        <div class="form-footer">
            <button type="button" class="btn-send">
                <i class="fas fa-paper-plane"></i> Send Message
            </button>
        </div>
    </div>

</div>

@* ── Bottom info cards ── *@
<div class="bottom-row">
    <div class="bottom-card">
        <div class="bc-icon blue"><i class="fas fa-tools"></i></div>
        <div>
            <div class="bc-title">Free Diagnostics</div>
            <div class="bc-desc">Bring your device in for a free check-up — no appointment needed. We'll tell you exactly what's wrong before any work begins.</div>
        </div>
    </div>
    <div class="bottom-card">
        <div class="bc-icon green"><i class="fas fa-shield-alt"></i></div>
        <div>
            <div class="bc-title">90-Day Warranty</div>
            <div class="bc-desc">Every repair is covered for 90 days. If the same fault returns, we'll fix it again at no charge — no questions asked.</div>
        </div>
    </div>
    <div class="bottom-card">
        <div class="bc-icon amber"><i class="fas fa-bolt"></i></div>
        <div>
            <div class="bc-title">Same-Day Repairs</div>
            <div class="bc-desc">Most screen, battery, and charging port repairs are completed the same day. Walk in and walk out with a working device.</div>
        </div>
    </div>
</div>
