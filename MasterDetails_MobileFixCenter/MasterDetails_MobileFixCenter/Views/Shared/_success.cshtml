
<div class="phix-alert phix-alert-success" role="alert">
    <div class="phix-alert-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
            <polyline points="22 4 12 14.01 9 11.01" />
        </svg>
    </div>
    <div class="phix-alert-body">
        <div class="phix-alert-title">Data Saved Successfully</div>
        <div class="phix-alert-msg">Your record has been inserted into the system. You can continue adding or go back to the list.</div>
    </div>
    <button class="phix-alert-close" aria-label="Close" onclick="this.closest('.phix-alert').style.display='none'">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
    </button>
</div>

<style>
    .phix-alert {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 16px 18px;
        border-radius: 12px;
        border-left: 4px solid transparent;
        margin-bottom: 20px;
        position: relative;
        animation: phixAlertIn 0.28s cubic-bezier(.22,.68,0,1.2);
    }

    @@keyframes phixAlertIn {
        from {
            opacity: 0;
            transform: translateY(-10px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    /* ── Success variant ── */
    .phix-alert-success {
        background: #f0fdf4;
        border-left-color: #16a34a;
    }

        .phix-alert-success .phix-alert-icon {
            background: #dcfce7;
        }

        .phix-alert-success .phix-alert-title {
            color: #15803d;
        }

        .phix-alert-success .phix-alert-msg {
            color: #14532d;
        }

        .phix-alert-success .phix-alert-close {
            color: #16a34a;
        }

            .phix-alert-success .phix-alert-close:hover {
                background: #dcfce7;
            }

    .phix-alert-icon {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .phix-alert-icon svg {
            width: 18px;
            height: 18px;
        }

    .phix-alert-body {
        flex: 1;
        padding-top: 2px;
    }

    .phix-alert-title {
        font-family: 'Syne', sans-serif;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 4px;
        letter-spacing: -0.01em;
    }

    .phix-alert-msg {
        font-size: 13px;
        line-height: 1.55;
        opacity: 0.85;
    }

    .phix-alert-close {
        background: none;
