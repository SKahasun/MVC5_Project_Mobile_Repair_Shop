        cursor: pointer;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.5;
        transition: opacity 0.15s, background 0.15s;
        flex-shrink: 0;
        padding: 0;
    }

        .phix-alert-close svg {
            width: 16px;
            height: 16px;
        }

        .phix-alert-close:hover {
            opacity: 1;
        }
</style>
