                    </ul>
                </div>

                @* ── Col 3: Company ── *@
                <div class="footer-col">
                    <h4><i class="fas fa-building"></i> Company</h4>
                    <ul>
                        <li><a href="@Url.Action("Index","Home")"><i class="fas fa-chevron-right"></i> Home</a></li>
                        <li><a href="@Url.Action("About","Home")"><i class="fas fa-chevron-right"></i> About Us</a></li>
                        <li><a href="@Url.Action("Index","Services")"><i class="fas fa-chevron-right"></i> Services</a></li>
                        <li><a href="@Url.Action("Index","Customer")"><i class="fas fa-chevron-right"></i> Customers</a></li>
                        <li><a href="@Url.Action("Contact","Home")"><i class="fas fa-chevron-right"></i> Contact</a></li>
                        <li><a href="@Url.Action("Create","Customer")"><i class="fas fa-chevron-right"></i> Book a Repair</a></li>
