                            <td>Closed</td>
                        </tr>
                    </table>
                </div>

                @* ── Col 5: Contact ── *@
                <div class="footer-col">
                    <h4><i class="fas fa-headset"></i> Contact Us</h4>

                    <div class="footer-contact-item">
                        <div class="fci-icon"><i class="fas fa-map-marker-alt"></i></div>
                        <div>
                            <div class="fci-label">Address</div>
                            <div class="fci-value">47 Tech Avenue, Kafrul<br />Dhaka 1216, Bangladesh</div>
                        </div>
                    </div>

                    <div class="footer-contact-item">
                        <div class="fci-icon"><i class="fas fa-phone"></i></div>
                        <div>
                            <div class="fci-label">Phone</div>
                            <div class="fci-value"><a href="tel:+8801700744776">+880 1700-PHIXPRO</a></div>
                        </div>
                    </div>

                    <div class="footer-contact-item">
                        <div class="fci-icon"><i class="fas fa-envelope"></i></div>
                        <div>
                            <div class="fci-label">Email</div>
