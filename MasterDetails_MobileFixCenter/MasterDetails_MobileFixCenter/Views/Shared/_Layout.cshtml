    @* Navbar *@
    <nav class="navbar-phixpro" id="mainNav">
        <div class="nav-inner">
            <a href="@Url.Action("Index", "Home")" class="brand" style="text-decoration:none">
                <div class="brand-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M17 2H7C5.9 2 5 2.9 5 4v16c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-5 15c-.83 0-1.5-.67-1.5-1.5S11.17 14 12 14s1.5.67 1.5 1.5S12.83 17 12 17zm3-6H9V5h6v6z" />
                    </svg>
                </div>
                <div class="brand-text">
                    <div class="brand-name">Phix<span>Pro</span></div>
                    <div class="brand-tagline">Mobile Repair Experts</div>
                </div>
            </a>

            <ul class="nav-links" id="navLinks">
                <li>@Html.ActionLink("Home", "Index", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                <li>@Html.ActionLink("Services", "Index", "Services", new { area = "" }, new { @class = "nav-link" })</li>
                <li>@Html.ActionLink("Customers", "Index", "Customer", new { area = "" }, new { @class = "nav-link" })</li>
                <li>@Html.ActionLink("About", "About", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                <li>@Html.ActionLink("Contact", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })</li>
            </ul>

            <div class="nav-cta">
                @Html.Partial("_LoginPartial")
                @Html.ActionLink("+ New Customer", "Create", "Customer", new { area = "" }, new { @class = "btn-amber" })
            </div>

            <button class="nav-toggler" id="navToggle" aria-label="Toggle menu">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </nav>

    @* Main content *@
    <main class="main-wrap">
        @RenderBody()
    </main>

    @* ════════════════════════════════════════
           FOOTER
        ════════════════════════════════════════ *@
    <footer class="site-footer">

        @* ── Newsletter Strip ── *@
        <div class="footer-newsletter">
            <div class="footer-newsletter-inner">
                <div class="fnl-left">
                    <div class="fnl-eyebrow">Stay Updated</div>
                    <div class="fnl-title">Get repair tips &amp; exclusive offers</div>
                    <div class="fnl-sub">Join 3,200+ PhixPro subscribers. No spam, unsubscribe anytime.</div>
                </div>
                <div class="fnl-form">
                    <input type="email" class="fnl-input" placeholder="Enter your email address" />
                    <a href="#" class="fnl-btn">
                        <i class="fas fa-paper-plane"></i> Subscribe
                    </a>
                </div>
            </div>
        </div>

        @* ── Main Footer Body ── *@
        <div class="footer-inner">
            <div class="footer-grid">

                @* ── Col 1: Brand ── *@
                <div class="footer-brand">
                    <div class="brand">
                        <div class="brand-icon">
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M17 2H7C5.9 2 5 2.9 5 4v16c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-5 15c-.83 0-1.5-.67-1.5-1.5S11.17 14 12 14s1.5.67 1.5 1.5S12.83 17 12 17zm3-6H9V5h6v6z" />
                            </svg>
                        </div>
                        <div class="brand-text">
                            <div class="brand-name">Phix<span>Pro</span></div>
                            <div class="brand-tagline">Mobile Repair Experts</div>
                        </div>
                    </div>
                    <p class="footer-desc">Dhaka's most trusted mobile repair center since 2018. Expert technicians, genuine parts, and a 90-day warranty on every single job.</p>

                    <div class="footer-rating">
                        <div class="footer-stars">★★★★★</div>
                        <div class="footer-rating-text"><strong>4.9 / 5</strong> · Based on 1,240+ reviews</div>
                    </div>

                    <div class="footer-socials">
                        <a href="#" class="fb" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="ig" title="Instagram"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="wa" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>
                        <a href="#" class="yt" title="YouTube"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>

                @* ── Col 2: Services ── *@
                <div class="footer-col">
                    <h4><i class="fas fa-tools"></i> Services</h4>
                    <ul>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Screen Replacement</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Battery Repair</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Water Damage</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Software &amp; Flashing</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Camera Repair</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Charging Port Fix</a></li>
