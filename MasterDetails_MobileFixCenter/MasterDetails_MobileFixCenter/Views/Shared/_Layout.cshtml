<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - PhixPro Service Center</title>
    <link href="~/Content/PagedList.css" rel="stylesheet" />
    <link href="~/Content/font-awesome.min.css" rel="stylesheet" />
    <link href="~/Content/bootstrap-utilities.rtl.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        :root {
            --navy: #0f2057;
            --navy-mid: #1a3284;
            --navy-light: #2348b0;
            --navy-pale: #e8edf8;
            --navy-dim: rgba(26,50,132,0.10);
            --blue-accent: #2d6be4;
            --blue-bright: #4a90f5;
            --surface: #ffffff;
            --panel: #f4f7fd;
            --border: rgba(26,50,132,0.12);
            --text: #0d1a3a;
            --muted: #5a6a8a;
            --white: #ffffff;
            --shadow: 0 4px 24px rgba(15,32,87,0.10);
            --shadow-lg: 0 8px 40px rgba(15,32,87,0.16);
            --nav-h: 68px;
            --radius: 14px;
            --font-head: 'Syne', sans-serif;
            --font-body: 'DM Sans', sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-body);
            background-color: #f0f4fb;
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow-x: hidden;
        }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background-image: radial-gradient(circle, rgba(26,50,132,0.06) 1px, transparent 1px);
                background-size: 28px 28px;
                pointer-events: none;
                z-index: 0;
            }

            body::after {
                content: '';
                position: fixed;
                top: -180px;
                right: -180px;
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, rgba(26,50,132,0.07) 0%, transparent 65%);
                pointer-events: none;
                z-index: 0;
            }

        .blob-amber {
            position: fixed;
            bottom: -120px;
            left: -120px;
            width: 450px;
            height: 450px;
            background: radial-gradient(circle, rgba(74,144,245,0.07) 0%, transparent 65%);
            pointer-events: none;
            z-index: 0;
        }

        /* ─── TOP BAR ─── */
        .topbar {
            background: var(--navy);
            font-size: 12px;
            color: rgba(255,255,255,0.75);
            padding: 7px 0;
            position: relative;
            z-index: 100;
        }

        .topbar-inner {
            max-width: 1280px;
            margin: auto;
            padding: 0 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .topbar span {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .topbar i {
            color: #7eb5ff;
            font-size: 11px;
        }

        .topbar .badge-open {
            background: rgba(255,255,255,0.12);
            color: #a8d4ff;
            border: 1px solid rgba(255,255,255,0.2);
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 0.05em;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .topbar .badge-open::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: #4ade80;
                animation: pulse-dot 1.5s infinite;
            }

        @@keyframes pulse-dot {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(0.7);
            }
        }

        /* ─── NAVBAR ─── */
        .navbar-phixpro {
            height: var(--nav-h);
            background: var(--white);
            border-bottom: 2px solid var(--navy-pale);
            position: sticky;
            top: 0;
            z-index: 200;
            transition: box-shadow 0.3s;
        }

            .navbar-phixpro.scrolled {
                box-shadow: var(--shadow-lg);
                border-bottom-color: rgba(26,50,132,0.18);
            }

        .nav-inner {
            max-width: 1280px;
            margin: auto;
            padding: 0 24px;
            height: 100%;
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none !important;
            flex-shrink: 0;
        }

        .brand-icon {
            width: 42px;
            height: 42px;
            background: linear-gradient(135deg, var(--navy-mid) 0%, var(--navy-light) 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            box-shadow: 0 4px 14px rgba(26,50,132,0.35);
        }

            .brand-icon::after {
                content: '';
                position: absolute;
                inset: -1px;
                border-radius: 11px;
                border: 1.5px solid rgba(74,144,245,0.5);
            }

            .brand-icon svg {
                width: 22px;
                height: 22px;
                fill: #ffffff;
            }

        .brand-text {
            line-height: 1;
        }

        .brand-name {
            font-family: var(--font-head);
            font-size: 22px;
            font-weight: 800;
            color: var(--navy);
            letter-spacing: -0.02em;
        }

            .brand-name span {
                color: var(--blue-accent);
            }

        .brand-tagline {
            font-size: 9px;
            color: var(--muted);
            letter-spacing: 0.18em;
            text-transform: uppercase;
            margin-top: 3px;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 2px;
            list-style: none;
            flex: 1;
        }

            .nav-links .nav-link {
                font-family: var(--font-body);
                font-size: 14px;
                font-weight: 500;
                color: var(--muted) !important;
                padding: 8px 14px !important;
                border-radius: 8px;
                text-decoration: none;
                transition: color 0.2s, background 0.2s;
                display: flex;
                align-items: center;
                gap: 7px;
            }

                .nav-links .nav-link i {
                    font-size: 13px;
                }

                .nav-links .nav-link:hover {
                    color: var(--navy) !important;
                    background: var(--navy-dim);
                }

                .nav-links .nav-link.active {
                    color: var(--navy-mid) !important;
                    background: var(--navy-pale);
                    font-weight: 600;
                }

        .nav-cta {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
            margin-left: auto;
        }

        .btn-amber {
            background: linear-gradient(135deg, var(--navy-mid), var(--navy-light));
            color: var(--white) !important;
            font-family: var(--font-head);
            font-size: 13px;
            font-weight: 700;
            padding: 9px 20px;
            border-radius: 8px;
            text-decoration: none;
            border: none;
            cursor: pointer;
            letter-spacing: 0.01em;
            transition: filter 0.2s, transform 0.15s, box-shadow 0.2s;
            display: flex;
            align-items: center;
            gap: 7px;
            white-space: nowrap;
            box-shadow: 0 3px 12px rgba(26,50,132,0.3);
        }

            .btn-amber:hover {
                filter: brightness(1.1);
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(26,50,132,0.4);
                color: var(--white) !important;
                text-decoration: none !important;
            }

        .nav-toggler {
            display: none;
            background: var(--navy-dim);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 8px 12px;
            cursor: pointer;
            color: var(--navy-mid);
            font-size: 18px;
            margin-left: auto;
        }

        /* ─── MAIN CONTENT ─── */
        .main-wrap {
            flex: 1;
            max-width: 1280px;
            width: 100%;
            margin: 0 auto;
            padding: 36px 24px;
            position: relative;
            z-index: 1;
        }

        /* ─── SHARED COMPONENT STYLES ─── */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            gap: 12px;
            flex-wrap: wrap;
        }

        .page-title {
            font-family: var(--font-head);
            font-size: 26px;
            font-weight: 800;
            color: var(--navy);
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .page-title::before {
                content: '';
                display: block;
                width: 4px;
                height: 28px;
                background: linear-gradient(to bottom, var(--blue-accent), var(--navy-light));
                border-radius: 4px;
            }

        .card-phix {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
        }

            .card-phix:hover {
                border-color: rgba(26,50,132,0.25);
                transform: translateY(-2px);
                box-shadow: var(--shadow-lg);
            }

        .table {
            color: var(--text);
        }

            .table thead th {
                border-bottom: 2px solid var(--navy-pale);
                font-family: var(--font-head);
                font-size: 11px;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--navy-mid);
                padding: 14px 16px;
                background: var(--panel);
            }

            .table tbody td {
                border-color: var(--border);
                padding: 13px 16px;
                font-size: 14px;
                vertical-align: middle;
                color: var(--text);
            }

            .table tbody tr:hover {
                background: var(--navy-pale);
            }

        .form-control, .form-select {
            background: var(--white) !important;
            border: 1.5px solid var(--border) !important;
            border-radius: 8px !important;
            color: var(--text) !important;
            font-family: var(--font-body);
            font-size: 14px;
            padding: 10px 14px !important;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--blue-accent) !important;
                box-shadow: 0 0 0 3px rgba(45,107,228,0.15) !important;
                outline: none;
            }

        label {
            color: var(--navy);
            font-size: 13px;
            margin-bottom: 6px;
            font-weight: 600;
        }

        .btn-primary, .btn-success {
            background: linear-gradient(135deg, var(--navy-mid), var(--navy-light)) !important;
            border: none !important;
            color: var(--white) !important;
            font-weight: 700;
            font-family: var(--font-head);
            border-radius: 8px !important;
            letter-spacing: 0.01em;
            box-shadow: 0 3px 10px rgba(26,50,132,0.25) !important;
        }

            .btn-primary:hover, .btn-success:hover {
                filter: brightness(1.1);
                box-shadow: 0 5px 16px rgba(26,50,132,0.35) !important;
            }

        .btn-danger {
            background: rgba(220,38,38,0.08) !important;
            border: 1.5px solid rgba(220,38,38,0.3) !important;
            color: #dc2626 !important;
            border-radius: 8px !important;
        }

            .btn-danger:hover {
                background: rgba(220,38,38,0.15) !important;
            }

        .btn-secondary, .btn-warning {
            background: var(--navy-pale) !important;
            border: 1.5px solid var(--border) !important;
            color: var(--navy-mid) !important;
            border-radius: 8px !important;
            font-weight: 600;
        }

            .btn-secondary:hover, .btn-warning:hover {
                background: rgba(26,50,132,0.12) !important;
            }

        .pagination .page-item .page-link {
            background: var(--white);
            border-color: var(--border);
            color: var(--muted);
            border-radius: 6px !important;
            margin: 0 2px;
            font-size: 13px;
        }

        .pagination .page-item.active .page-link {
            background: var(--navy-mid);
            border-color: var(--navy-mid);
            color: var(--white);
            font-weight: 700;
        }

        .pagination .page-item .page-link:hover {
            background: var(--navy-pale);
            color: var(--navy-mid);
            border-color: var(--border);
        }

        .alert {
            border-radius: var(--radius);
            border: 1.5px solid var(--border);
            background: var(--white);
        }

        .alert-success {
            border-color: rgba(22,163,74,0.4) !important;
            color: #16a34a !important;
            background: #f0fdf4 !important;
        }

        .alert-danger {
            border-color: rgba(220,38,38,0.3) !important;
            color: #dc2626 !important;
            background: #fff1f1 !important;
        }

        /* ════════════════════════════════════════
           ─── FOOTER ───
        ════════════════════════════════════════ */
        footer.site-footer {
            background: #080f2e;
            border-top: none;
            position: relative;
            z-index: 1;
            overflow: hidden;
        }

            /* Decorative blobs inside footer */
            footer.site-footer::before {
                content: '';
                position: absolute;
                right: -120px;
                top: -120px;
                width: 500px;
                height: 500px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(26,50,132,0.18) 0%, transparent 65%);
                pointer-events: none;
            }

            footer.site-footer::after {
                content: '';
                position: absolute;
                left: -80px;
                bottom: 60px;
                width: 360px;
                height: 360px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(74,144,245,0.10) 0%, transparent 65%);
                pointer-events: none;
            }

        /* ── Newsletter strip ── */
        .footer-newsletter {
            background: linear-gradient(135deg, #1a3284 0%, #2348b0 100%);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            padding: 32px 24px;
            position: relative;
            z-index: 1;
        }

        .footer-newsletter-inner {
            max-width: 1280px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            flex-wrap: wrap;
        }

        .fnl-left {
            flex: 1;
            min-width: 240px;
        }

        .fnl-eyebrow {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.45);
            margin-bottom: 5px;
            font-family: 'DM Sans', sans-serif;
        }

        .fnl-title {
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 3px;
        }

        .fnl-sub {
            font-size: 12px;
            color: rgba(255,255,255,0.5);
            font-family: 'DM Sans', sans-serif;
        }

        .fnl-form {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        .fnl-input {
            background: rgba(255,255,255,0.10);
            border: 1.5px solid rgba(255,255,255,0.2);
            border-radius: 9px;
            color: #fff;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            padding: 10px 16px;
            outline: none;
            width: 240px;
            transition: border-color 0.2s, background 0.2s;
        }

            .fnl-input::placeholder {
                color: rgba(255,255,255,0.4);
            }

            .fnl-input:focus {
                border-color: rgba(255,255,255,0.5);
                background: rgba(255,255,255,0.15);
            }

        .fnl-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: #fff;
            color: #1a3284 !important;
            font-family: 'Syne', sans-serif;
            font-size: 12px;
            font-weight: 800;
            padding: 10px 20px;
            border-radius: 9px;
            border: none;
            cursor: pointer;
            white-space: nowrap;
            transition: transform 0.15s, box-shadow 0.2s;
            box-shadow: 0 3px 12px rgba(0,0,0,0.2);
            text-decoration: none !important;
        }

            .fnl-btn:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(0,0,0,0.28);
            }

        /* ── Main footer body ── */
        .footer-inner {
            max-width: 1280px;
            margin: auto;
            padding: 56px 24px 0;
            position: relative;
            z-index: 1;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.8fr 1fr 1fr 1fr 1fr;
            gap: 40px;
            margin-bottom: 48px;
        }

        /* Brand col */
        .footer-brand .brand-name {
            font-size: 24px;
            color: var(--white) !important;
        }

            .footer-brand .brand-name span {
                color: #7eb5ff !important;
            }

        .footer-brand .brand-tagline {
            color: rgba(255,255,255,0.40) !important;
        }

        .footer-brand .brand-icon {
            background: rgba(255,255,255,0.10) !important;
            box-shadow: none !important;
        }

            .footer-brand .brand-icon::after {
                border-color: rgba(255,255,255,0.18) !important;
            }

        .footer-desc {
            font-size: 13px;
            color: rgba(255,255,255,0.48);
            line-height: 1.75;
            margin-top: 16px;
            max-width: 250px;
        }

        /* Rating stars */
        .footer-rating {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 16px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            padding: 10px 14px;
        }

        .footer-stars {
            color: #ffd166;
            font-size: 13px;
            letter-spacing: 1px;
        }

        .footer-rating-text {
            font-size: 12px;
            color: rgba(255,255,255,0.55);
            font-family: 'DM Sans', sans-serif;
        }

            .footer-rating-text strong {
                color: #fff;
                font-weight: 700;
            }

        /* Socials */
        .footer-socials {
            display: flex;
            gap: 8px;
            margin-top: 18px;
        }

            .footer-socials a {
                width: 36px;
                height: 36px;
                display: flex;
                align-items: center;
                justify-content: center;
                background: rgba(255,255,255,0.07);
                border: 1px solid rgba(255,255,255,0.13);
                border-radius: 9px;
                color: rgba(255,255,255,0.55);
                font-size: 14px;
                text-decoration: none;
                transition: color 0.2s, border-color 0.2s, background 0.2s;
            }

                .footer-socials a:hover {
                    color: var(--white);
                    border-color: rgba(255,255,255,0.35);
                    background: rgba(255,255,255,0.13);
                }

                .footer-socials a.fb:hover {
                    background: #1877f2;
                    border-color: #1877f2;
                    color: #fff;
                }

                .footer-socials a.ig:hover {
                    background: #e1306c;
                    border-color: #e1306c;
                    color: #fff;
                }

                .footer-socials a.wa:hover {
                    background: #25d366;
                    border-color: #25d366;
                    color: #fff;
                }

                .footer-socials a.yt:hover {
                    background: #ff0000;
                    border-color: #ff0000;
                    color: #fff;
                }

        /* Footer columns */
        .footer-col h4 {
            font-family: 'Syne', sans-serif;
            font-size: 13px;
            font-weight: 700;
            color: rgba(255,255,255,0.90);
            letter-spacing: 0.01em;
            margin-bottom: 18px;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .footer-col h4 i {
                font-size: 11px;
                color: #7eb5ff;
                width: 18px;
                height: 18px;
                background: rgba(126,181,255,0.12);
                border-radius: 4px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

        .footer-col ul {
            list-style: none;
        }

            .footer-col ul li {
                margin-bottom: 11px;
            }

                .footer-col ul li a {
                    font-size: 13px;
                    color: rgba(255,255,255,0.52);
                    text-decoration: none;
                    transition: color 0.2s, padding-left 0.2s;
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    font-family: 'DM Sans', sans-serif;
                }

                    .footer-col ul li a i {
                        font-size: 10px;
                        color: rgba(255,255,255,0.25);
                        transition: color 0.2s;
                        width: 14px;
                    }

                    .footer-col ul li a:hover {
                        color: #fff;
                        padding-left: 4px;
                    }

                        .footer-col ul li a:hover i {
                            color: #7eb5ff;
                        }

        /* Hours table */
        .hours-table {
            width: 100%;
        }

            .hours-table tr td {
                padding: 6px 0;
                font-size: 12px;
                font-family: 'DM Sans', sans-serif;
                border-bottom: 1px solid rgba(255,255,255,0.05);
            }

            .hours-table tr:last-child td {
                border-bottom: none;
            }

            .hours-table tr td:first-child {
                color: rgba(255,255,255,0.55);
            }

            .hours-table tr td:last-child {
                text-align: right;
                color: rgba(255,255,255,0.80);
                font-weight: 500;
            }

        .hours-today td {
        }

            .hours-today td:first-child {
                color: #4ade80 !important;
                font-weight: 600;
            }

            .hours-today td:last-child {
                color: #4ade80 !important;
            }

        .closed-day td:first-child {
            color: rgba(255,255,255,0.3) !important;
        }

        .closed-day td:last-child {
            color: rgba(220,38,38,0.7) !important;
            font-size: 11px;
        }

        /* Contact items */
        .footer-contact-item {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 14px;
        }

            .footer-contact-item:last-child {
                margin-bottom: 0;
            }

        .fci-icon {
            width: 30px;
            height: 30px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.10);
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #7eb5ff;
            font-size: 11px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .fci-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.35);
            margin-bottom: 2px;
            font-family: 'DM Sans', sans-serif;
        }

        .fci-value {
            font-size: 13px;
            color: rgba(255,255,255,0.75);
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
        }

            .fci-value a {
                color: rgba(255,255,255,0.75) !important;
                text-decoration: none !important;
                transition: color 0.15s;
            }

                .fci-value a:hover {
                    color: #fff !important;
                }

        /* Map link */
        .footer-map-link {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.10);
            border-radius: 9px;
            padding: 10px 14px;
            margin-top: 16px;
            text-decoration: none !important;
            transition: background 0.15s, border-color 0.15s;
        }

            .footer-map-link:hover {
                background: rgba(255,255,255,0.11);
                border-color: rgba(255,255,255,0.22);
            }

            .footer-map-link span {
                font-size: 12px;
                color: rgba(255,255,255,0.65);
                font-family: 'DM Sans', sans-serif;
                font-weight: 500;
            }

            .footer-map-link i {
                color: #7eb5ff;
                font-size: 12px;
            }

            .footer-map-link .arrow {
                margin-left: auto;
                color: rgba(255,255,255,0.3);
                font-size: 11px;
            }

        /* ── Divider with trust badges ── */
        .footer-trust {
            border-top: 1px solid rgba(255,255,255,0.08);
            padding: 24px 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
        }

        .trust-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.09);
            border-radius: 10px;
            padding: 10px 16px;
            transition: background 0.15s, border-color 0.15s;
        }

            .trust-badge:hover {
                background: rgba(255,255,255,0.09);
                border-color: rgba(255,255,255,0.18);
            }

        .tb-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

            .tb-icon.blue {
                background: rgba(126,181,255,0.15);
                color: #7eb5ff;
            }

            .tb-icon.green {
                background: rgba(74,222,128,0.12);
                color: #4ade80;
            }

            .tb-icon.amber {
                background: rgba(255,209,102,0.12);
                color: #ffd166;
            }

            .tb-icon.red {
                background: rgba(248,113,113,0.12);
                color: #f87171;
            }

        .tb-title {
            font-family: 'Syne', sans-serif;
            font-size: 13px;
            font-weight: 700;
            color: rgba(255,255,255,0.85);
            line-height: 1;
            margin-bottom: 2px;
        }

        .tb-sub {
            font-size: 11px;
            color: rgba(255,255,255,0.38);
            font-family: 'DM Sans', sans-serif;
        }

        /* ── Bottom bar ── */
        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.07);
            padding: 20px 24px;
            position: relative;
            z-index: 1;
        }

        .footer-bottom-inner {
            max-width: 1280px;
            margin: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

        .footer-bottom-left {
            display: flex;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
        }

            .footer-bottom-left p {
                font-size: 12px;
                color: rgba(255,255,255,0.35);
                font-family: 'DM Sans', sans-serif;
            }

        .footer-legal-links {
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .footer-legal-links a {
                font-size: 11px;
                color: rgba(255,255,255,0.30);
                text-decoration: none;
                font-family: 'DM Sans', sans-serif;
                transition: color 0.15s;
            }

                .footer-legal-links a:hover {
                    color: rgba(255,255,255,0.65);
                }

            .footer-legal-links span {
                color: rgba(255,255,255,0.15);
                font-size: 10px;
            }

        .footer-bottom-right {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .footer-made {
            font-size: 11px;
            color: rgba(255,255,255,0.28);
            font-family: 'DM Sans', sans-serif;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .footer-made i {
                color: #f87171;
                font-size: 10px;
            }

        /* ─── STATUS STRIP ─── */
        .status-strip {
            background: var(--navy-light);
            text-align: center;
            padding: 10px;
            font-size: 12px;
            color: rgba(255,255,255,0.9);
            font-weight: 500;
            letter-spacing: 0.05em;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            position: relative;
            z-index: 100;
        }

            .status-strip i {
                font-size: 11px;
                color: #a8d4ff;
            }

        /* ─── RESPONSIVE ─── */
        @@media (max-width: 1100px) {
            .footer-grid {
                grid-template-columns: 1.4fr 1fr 1fr 1fr;
            }

                .footer-grid > div:last-child {
                    grid-column: span 2;
                }
        }

        @@media (max-width: 900px) {
            .footer-grid {
                grid-template-columns: 1fr 1fr;
                gap: 28px;
            }

                .footer-grid > div:last-child {
                    grid-column: span 1;
                }
        }

        @@media (max-width: 640px) {
            .nav-links, .nav-cta {
                display: none;
            }

                .nav-links.open {
                    display: flex;
                    flex-direction: column;
                    position: absolute;
                    top: var(--nav-h);
                    left: 0;
                    right: 0;
                    background: var(--white);
                    border-bottom: 2px solid var(--border);
                    padding: 12px;
                    z-index: 300;
                    box-shadow: var(--shadow-lg);
                }

            .nav-toggler {
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                gap: 24px;
            }

            .topbar-inner {
                justify-content: center;
            }

            .fnl-form {
                width: 100%;
            }

            .fnl-input {
                flex: 1;
                width: auto;
            }

            .footer-trust {
                gap: 8px;
            }

            .trust-badge {
                flex: 1;
                min-width: 140px;
            }
        }
    </style>
</head>
<body>

    <div class="blob-amber"></div>

    @* Announcement bar *@
    <div class="status-strip">
        <i class="fas fa-bolt"></i>
        <span>Same-day repair available · Free diagnostics on all devices · Genuine parts guaranteed</span>
        <i class="fas fa-bolt"></i>
    </div>

    @* Top info bar *@
    <div class="topbar">
        <div class="topbar-inner">
            <span><i class="fas fa-map-marker-alt"></i> 47 Tech Avenue, Dhaka 1216</span>
            <span><i class="fas fa-phone"></i> +880 1700-PHIXPRO</span>
            <span><i class="fas fa-clock"></i> Mon–Sat · 9:00 AM – 8:00 PM</span>
